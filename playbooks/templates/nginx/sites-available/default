server {
	listen 80 default_server;
	listen [::]:80 default_server;

	server_name _;

	return 404 "Not found.\n";
}

server {
	listen 443 ssl default_server;
	listen [::]:443 ssl default_server;

	server_name _;

	ssl_certificate /etc/ssl/certs/ssl-cert-snakeoil.pem;
	ssl_certificate_key /etc/ssl/private/ssl-cert-snakeoil.key;

	return 404 "Not found.\n";
}