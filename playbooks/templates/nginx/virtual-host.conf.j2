# Virtual Host configuration for {{ item.name }}

server {
	listen 80;
	listen [::]:80;

	server_name {{ item.name }} www.{{ item.name }};

{% if item.ssl | default(false) %}
	return 301 https://$host$request_uri;
{% else %}
	root /var/www/{{ item.name }};

	index index.html index.php;

{% if item.https_redirect | default(false) %}
	if ($http_x_forwarded_proto = "http") {
		return 301 https://$host$request_uri;
	}
{% endif %}
	location / {
		try_files $uri $uri/ =404;
	}
{% endif %}
}

{% if item.ssl | default(false) %}
server {
	listen 443 ssl;
	listen [::]:443 ssl;

	server_name {{ item.name }} www.{{ item.name }};

	ssl_certificate /etc/letsencrypt/live/{{ item.name }}/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/{{ item.name }}/privkey.pem;
	include /etc/letsencrypt/options-ssl-nginx.conf;
	ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

	root /var/www/{{ item.name }};

	index index.html index.php;

	location / {
		try_files $uri $uri/ =404;
	}
}
{% endif %}